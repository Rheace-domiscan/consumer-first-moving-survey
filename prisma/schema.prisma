generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Survey {
  id                  String       @id @default(cuid())
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  ownerClerkUserId    String
  status              SurveyStatus @default(DRAFT)
  title               String?
  originPostcode      String?
  destinationPostcode String?
  propertyType        String?
  moveWindow          String?
  completeness        String?
  notes               String?
  rooms               SurveyRoom[]

  @@index([ownerClerkUserId, updatedAt])
}

model SurveyRoom {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  surveyId    String
  name        String
  status      String?
  mediaCount  Int           @default(0)
  notes       String?
  survey      Survey        @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  media       SurveyMedia[]
}

model SurveyMedia {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  surveyRoomId String
  kind         String
  fileName     String
  contentType  String?
  fileSize     Int?
  storageKey   String
  storageUrl   String?
  uploadStatus String   @default("UPLOADED")
  notes        String?
  surveyRoom   SurveyRoom @relation(fields: [surveyRoomId], references: [id], onDelete: Cascade)
}

enum SurveyStatus {
  DRAFT
  COLLECTING_MEDIA
  SUBMITTED
  PROCESSING
  READY_TO_SHARE
  REVIEW_REQUIRED
  ARCHIVED
}
