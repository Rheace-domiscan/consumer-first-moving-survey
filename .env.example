DATABASE_URL="file:./dev.db"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
ADMIN_CLERK_USER_IDS=
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payments
# Use "stripe" in deployed environments and leave unset locally to use the built-in mock unlock flow.
PAYMENTS_PROVIDER=
PAYMENTS_CURRENCY=usd
UNLOCK_PRICE_STANDARD_CENTS=2900
UNLOCK_PRICE_PREMIUM_CENTS=5900
STRIPE_COMPANY_TEAM_PRICE_ID=
COMPANY_TEAM_PLAN_INCLUDED_UNLOCKS=10
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
JOB_RUNNER_SECRET=

# Extraction worker
LOCAL_MEDIA_ROOT=.data/media-cache
EXTRACTION_RETRY_LIMIT=3
EXTRACTION_WORKER_LEASE_SECONDS=120
EXTRACTION_WORKER_POLL_MS=8000

# Cloudflare R2 / S3-compatible storage
STORAGE_PROVIDER="cloudflare-r2"
STORAGE_BUCKET="domiscan-moving-survey-media"
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://717af61c7d9a9131e2ff5c7738addaa2.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
# Optional. Leave blank unless you enable r2.dev or connect a custom domain.
STORAGE_PUBLIC_BASE_URL=
